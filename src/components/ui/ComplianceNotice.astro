---
import type { TranslationKeys } from '@/i18n/types';

interface Props {
  t: TranslationKeys;
}

const { t } = Astro.props;
---

<div class="flex items-start gap-3 bg-blue-50 border-l-4 border-electric rounded-r-xl p-4 text-sm text-slate-600">
  <svg class="shrink-0 mt-0.5 text-electric" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    <path d="M9 12l2 2 4-4"/>
  </svg>
  <p class="leading-relaxed">{t.compliance.notice}</p>
</div>
