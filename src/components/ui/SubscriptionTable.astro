---
import ComplianceNotice from './ComplianceNotice.astro';
import type { TranslationKeys } from '@/i18n/types';
import type { Lang } from '@/i18n/types';

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;
const { plans, billing } = t.fincaCare;

const tiers = [
  {
    key: 'digital',
    plan: plans.digital,
    tier: 'Tier 1',
    style: 'base',
  },
  {
    key: 'essential',
    plan: plans.essential,
    tier: 'Tier 2',
    style: 'featured',
  },
  {
    key: 'elite',
    plan: plans.elite,
    tier: 'Tier 3',
    style: 'premium',
  },
] as const;
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-start">
  {tiers.map(({ key, plan, tier, style }) => {
    const isFeatured = style === 'featured';
    const isPremium = style === 'premium';
    return (
      <div class={[
        'relative rounded-2xl border-2 p-8 flex flex-col',
        isFeatured ? 'bg-navy border-electric shadow-2xl shadow-blue-900/30 md:-mt-4 md:-mb-4' : '',
        isPremium ? 'bg-slate-900 border-slate-700' : '',
        !isFeatured && !isPremium ? 'bg-white border-slate-border' : '',
      ].join(' ')}>

        {plan.badge && (
          <div class="absolute -top-4 left-1/2 -translate-x-1/2">
            <span class="bg-electric text-white text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-full shadow-lg shadow-blue-400/40 whitespace-nowrap">
              {plan.badge}
            </span>
          </div>
        )}

        <div class={plan.badge ? 'mt-3 mb-6' : 'mb-6'}>
          <p class={`text-xs font-bold uppercase tracking-widest mb-2 ${isFeatured ? 'text-electric' : isPremium ? 'text-slate-400' : 'text-electric'}`}>{tier}</p>
          <h3 class={`font-bold text-2xl mb-1 ${isFeatured || isPremium ? 'text-white' : 'text-navy'}`}>{plan.name}</h3>
          <p class={`text-sm leading-snug mb-5 ${isFeatured ? 'text-slate-300' : isPremium ? 'text-slate-400' : 'text-slate-400'}`}>{plan.tagline}</p>

          {/* Monthly price (shown by default) */}
          <div class="plan-price-monthly">
            <div class="flex items-center gap-2 mb-0.5">
              <span class={`text-xs line-through ${isFeatured ? 'text-slate-400' : isPremium ? 'text-slate-500' : 'text-slate-300'}`}>{plan.price}</span>
              <span class="bg-electric/15 text-electric text-xs font-bold px-2 py-0.5 rounded-full">{billing.promoTag}</span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class={`text-4xl font-bold ${isFeatured || isPremium ? 'text-white' : 'text-navy'}`}>{plan.pricePromo}</span>
              <span class={`text-sm ${isFeatured ? 'text-slate-300' : isPremium ? 'text-slate-400' : 'text-slate-400'}`}>{plan.period}</span>
            </div>
          </div>

          {/* Annual price (hidden by default, shown when toggle is Annual) */}
          <div class="plan-price-annual hidden">
            <div class="flex items-center gap-2 mb-0.5 flex-wrap">
              <span class={`text-xs line-through ${isFeatured ? 'text-slate-400' : isPremium ? 'text-slate-500' : 'text-slate-300'}`}>{plan.price}</span>
              <span class="bg-electric/15 text-electric text-xs font-bold px-2 py-0.5 rounded-full">{billing.promoTag}</span>
              <span class="bg-green-500/15 text-green-400 text-xs font-bold px-2 py-0.5 rounded-full">+ {billing.annualBadge}</span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class={`text-4xl font-bold ${isFeatured || isPremium ? 'text-white' : 'text-navy'}`}>{plan.priceAnnual}</span>
              <span class={`text-sm ${isFeatured ? 'text-slate-300' : isPremium ? 'text-slate-400' : 'text-slate-400'}`}>{plan.period}</span>
            </div>
            <p class={`text-xs mt-1 ${isFeatured ? 'text-slate-400' : isPremium ? 'text-slate-500' : 'text-slate-400'}`}>{plan.priceAnnualBilled}</p>
          </div>
        </div>

        <ul class="flex flex-col gap-3 mb-8 flex-1 list-none m-0 p-0">
          {plan.features.map((feature) => (
            <li class={`flex items-start gap-3 text-sm ${isFeatured ? 'text-slate-200' : isPremium ? 'text-slate-300' : 'text-slate-600'}`}>
              <svg class={`shrink-0 mt-0.5 ${isFeatured ? 'text-electric' : isPremium ? 'text-slate-400' : 'text-electric'}`} width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              {feature}
            </li>
          ))}
        </ul>

        <a
          href={`/${lang}/contact/?plan=${key}`}
          class={[
            'block text-center font-semibold px-6 py-3 rounded-xl transition-all duration-200',
            isFeatured ? 'bg-electric text-white hover:bg-blue-400 shadow-lg shadow-blue-900/40' : '',
            isPremium ? 'bg-white text-slate-900 hover:bg-slate-100' : '',
            !isFeatured && !isPremium ? 'bg-white text-navy border-2 border-navy hover:bg-navy hover:text-white' : '',
          ].join(' ')}
        >
          {plan.cta}
        </a>
      </div>
    );
  })}
</div>

<div class="mt-8">
  <ComplianceNotice t={t} />
</div>
