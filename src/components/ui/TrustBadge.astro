---
import type { TranslationKeys } from '@/i18n/types';

interface Props {
  t: TranslationKeys;
}

const { t } = Astro.props;
const whyUs = (t as any).whyUs;

const icons = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
];
---

<section class="bg-white py-16 md:py-20" aria-labelledby="why-us-heading">
  <div class="container-xl">
    <div class="text-center mb-12">
      <p class="text-electric text-xs font-bold uppercase tracking-widest mb-3">
        {whyUs.badge}
      </p>
      <h2 id="why-us-heading" class="text-3xl md:text-4xl font-bold text-navy">
        {whyUs.heading}
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
      {whyUs.items.map((item: { title: string; body: string }, index: number) => (
        <div class="flex flex-col gap-4 p-6 bg-slate-bg rounded-2xl border border-slate-border">
          <div class="w-11 h-11 rounded-xl bg-electric/10 flex items-center justify-center text-electric">
            <div set:html={icons[index]} />
          </div>
          <h3 class="font-bold text-navy text-lg">{item.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
