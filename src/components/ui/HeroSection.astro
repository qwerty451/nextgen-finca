---
import type { TranslationKeys } from '@/i18n/types';
import type { Lang } from '@/i18n/types';

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;
---

<section class="relative bg-slate-bg overflow-hidden" aria-label="Hero">
  <!-- Background grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0F1F3D" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="container-xl relative py-20 md:py-28 lg:py-36">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-white border border-slate-border text-navy text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-6 shadow-sm">
        <span class="w-2 h-2 rounded-full bg-electric inline-block" aria-hidden="true"></span>
        {t.hero.badge}
      </div>

      <!-- Headline -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-navy leading-tight tracking-tight mb-6">
        {t.hero.headline}
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-slate-500 leading-relaxed max-w-2xl mx-auto mb-10">
        {t.hero.subheadline}
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`/${lang}/contact/`}
          class="inline-flex items-center gap-2 bg-electric text-white font-semibold px-8 py-4 rounded-xl hover:bg-blue-700 transition-all shadow-lg shadow-blue-200 hover:shadow-xl hover:shadow-blue-300 hover:-translate-y-0.5"
        >
          {t.hero.ctaPrimary}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href={`/${lang}/services/`}
          class="inline-flex items-center gap-2 bg-white text-navy font-semibold px-8 py-4 rounded-xl border-2 border-navy hover:bg-navy hover:text-white transition-all"
        >
          {t.hero.ctaSecondary}
        </a>
      </div>

      <!-- Trust line -->
      <p class="mt-8 text-slate-400 text-sm">
        {t.hero.trustLine}
      </p>
    </div>

    <!-- Hero visual: tech dashboard card -->
    <div class="mt-16 relative max-w-3xl mx-auto">
      <div class="bg-white rounded-2xl border border-slate-border shadow-2xl shadow-slate-200 overflow-hidden">
        <!-- Dashboard header bar -->
        <div class="bg-navy px-6 py-3 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-red-400" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-400" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-green-400" aria-hidden="true"></span>
          <span class="ml-4 text-slate-300 text-xs font-mono">NextGen Finca — Estate Dashboard</span>
        </div>
        <!-- Dashboard content preview -->
        <div class="p-6 grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { label: 'Connectivity', value: '↑ 589 Mbps', status: 'online' },
            { label: 'Security', value: '4 Cameras', status: 'online' },
            { label: 'Automation', value: '12 Devices', status: 'online' },
            { label: 'Solar', value: '94% SoC', status: 'online' },
          ].map((item) => (
            <div class="bg-slate-bg rounded-xl p-4 border border-slate-border">
              <div class="flex items-center gap-1.5 mb-2">
                <span class={`w-2 h-2 rounded-full ${item.status === 'online' ? 'bg-green-400' : 'bg-red-400'}`} aria-hidden="true"></span>
                <span class="text-slate-400 text-xs font-medium">{item.label}</span>
              </div>
              <p class="text-navy font-bold text-lg">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
      <!-- Decorative glow -->
      <div class="absolute -inset-4 bg-electric/5 rounded-3xl blur-2xl -z-10" aria-hidden="true"></div>
    </div>
  </div>
</section>
