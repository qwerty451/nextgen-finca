---
import type { TranslationKeys } from '@/i18n/types';
import type { Lang } from '@/i18n/types';

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;
---

<section class="relative bg-slate-bg overflow-hidden" aria-label="Hero">
  <!-- Background grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0F1F3D" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="container-xl relative py-20 md:py-28 lg:py-36">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-white border border-slate-border text-navy text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-6 shadow-sm">
        <span class="w-2 h-2 rounded-full bg-electric inline-block" aria-hidden="true"></span>
        {t.hero.badge}
      </div>

      <!-- Headline -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-navy leading-tight tracking-tight mb-6">
        {t.hero.headline}
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-slate-500 leading-relaxed max-w-2xl mx-auto mb-10">
        {t.hero.subheadline}
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 flex-wrap">
        <a
          href={`/${lang}/contact/`}
          class="inline-flex items-center gap-2 bg-electric text-white font-semibold px-8 py-4 rounded-xl hover:bg-blue-700 transition-all shadow-lg shadow-blue-200 hover:shadow-xl hover:shadow-blue-300 hover:-translate-y-0.5"
        >
          {t.hero.ctaPrimary}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href={`/${lang}/services/`}
          class="inline-flex items-center gap-2 bg-white text-navy font-semibold px-8 py-4 rounded-xl border-2 border-navy hover:bg-navy hover:text-white transition-all"
        >
          {t.hero.ctaSecondary}
        </a>
        <a
          href="https://wa.me/34639864420"
          class="inline-flex items-center gap-2 bg-white text-green-600 font-semibold px-8 py-4 rounded-xl border-2 border-green-500 hover:bg-green-500 hover:text-white transition-all"
          rel="noopener noreferrer"
          target="_blank"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>

      <!-- Trust line -->
      <p class="mt-8 text-slate-400 text-sm">
        {t.hero.trustLine}
      </p>
    </div>

    <!-- Hero visual -->
    <div class="mt-16 relative max-w-3xl mx-auto">
      <img
        src="/images/estate-dashboard.jpg"
        alt="Estate management dashboard on mobile device"
        class="w-full rounded-2xl shadow-2xl shadow-slate-200 object-cover"
        width="900"
        height="600"
      />
      <div class="absolute -inset-4 bg-electric/5 rounded-3xl blur-2xl -z-10" aria-hidden="true"></div>
    </div>
  </div>
</section>
