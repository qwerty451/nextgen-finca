---
import { SITE_URL } from '@/config/site';
import type { Lang } from '@/i18n/types';

interface Props {
  lang: Lang;
  pageType: 'home' | 'service' | 'contact' | 'finca-care';
  serviceName?: string;
  pageTitle?: string;
  pagePath?: string;
}

const { lang, pageType, serviceName, pageTitle, pagePath = '' } = Astro.props;

const pageUrl = `${SITE_URL}/${lang}/${pagePath ? pagePath + '/' : ''}`;

const localBusiness = {
  '@type': 'LocalBusiness',
  '@id': `${SITE_URL}/#business`,
  name: 'NextGen Finca',
  url: SITE_URL,
  telephone: '+34600000000',
  email: 'info@nextgenfinca.com',
  image: `${SITE_URL}/images/og/og-en.jpg`,
  description:
    'Premium smart estate engineering and automation for off-grid country homes in inland Spain. Specialists in Starlink, Ubiquiti, Home Assistant, Victron and Reolink integration.',
  priceRange: '€€€',
  areaServed: [
    { '@type': 'City', name: 'Almansa' },
    { '@type': 'City', name: 'Ontinyent' },
    { '@type': 'City', name: 'Yecla' },
    { '@type': 'City', name: 'Villena' },
  ],
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'Castilla-La Mancha',
    addressCountry: 'ES',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '38.87',
    longitude: '-1.09',
  },
  sameAs: [],
  knowsLanguage: ['en', 'nl', 'de', 'es'],
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website`,
  url: SITE_URL,
  name: 'NextGen Finca',
  inLanguage: lang,
};

const breadcrumbHome = {
  '@type': 'ListItem',
  position: 1,
  name: 'Home',
  item: `${SITE_URL}/${lang}/`,
};

function buildSchema() {
  const graph: object[] = [localBusiness, websiteSchema];

  if (pageType === 'home') {
    graph.push({
      '@type': 'BreadcrumbList',
      itemListElement: [breadcrumbHome],
    });
  }

  if (pageType === 'service' && serviceName) {
    graph.push(
      {
        '@type': 'Service',
        name: serviceName,
        provider: { '@id': `${SITE_URL}/#business` },
        areaServed: localBusiness.areaServed,
        url: pageUrl,
      },
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          breadcrumbHome,
          { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE_URL}/${lang}/services/` },
          { '@type': 'ListItem', position: 3, name: serviceName, item: pageUrl },
        ],
      }
    );
  }

  if (pageType === 'contact') {
    graph.push(
      { '@type': 'ContactPage', url: pageUrl, name: pageTitle ?? 'Contact' },
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          breadcrumbHome,
          { '@type': 'ListItem', position: 2, name: pageTitle ?? 'Contact', item: pageUrl },
        ],
      }
    );
  }

  if (pageType === 'finca-care') {
    graph.push({
      '@type': 'BreadcrumbList',
      itemListElement: [
        breadcrumbHome,
        { '@type': 'ListItem', position: 2, name: 'Finca Care', item: pageUrl },
      ],
    });
  }

  return { '@context': 'https://schema.org', '@graph': graph };
}

const schema = buildSchema();
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
