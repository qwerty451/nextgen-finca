---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { NAV_LINKS } from '@/config/site';
import type { Lang, TranslationKeys } from '@/i18n/types';

interface Props {
  lang: Lang;
  currentPath: string;
  t: TranslationKeys;
}

const { lang, currentPath, t } = Astro.props;
const links = NAV_LINKS(lang);
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-border">
  <nav class="container-xl flex items-center justify-between h-20" aria-label="Main navigation">
    <!-- Logo -->
    <a href={`/${lang}/`} class="flex items-center shrink-0" aria-label="NextGen Finca — Home">
      <img src="/logo.svg" alt="NextGen Finca" style="height: 73px; width: auto;" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      <ul class="flex items-center gap-6 list-none m-0 p-0">
        {links.slice(0, -1).map((link) => {
          const isActive = currentPath === link.href || (link.href !== `/${lang}/` && currentPath.startsWith(link.href));
          return (
            <li>
              <a
                href={link.href}
                class={`text-sm font-medium transition-colors hover:text-electric ${isActive ? 'text-electric border-b-2 border-electric pb-0.5' : 'text-slate-600'}`}
                aria-current={isActive ? 'page' : undefined}
              >
                {t.nav[link.key as keyof typeof t.nav]}
              </a>
            </li>
          );
        })}
      </ul>
      <LanguageSwitcher currentLang={lang} currentPath={currentPath} />
      <a
        href={`/${lang}/contact/`}
        class="inline-flex items-center gap-1.5 bg-electric text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors"
      >
        {t.nav.contact}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Mobile: hamburger button -->
    <button
      id="mobile-nav-btn"
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-md text-navy hover:bg-slate-100 transition-colors"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-hamburger" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="hidden border-t border-slate-border bg-white shadow-lg">
    <div class="container-xl py-5 flex flex-col gap-2">
      <ul class="flex flex-col gap-1 list-none m-0 p-0">
        {links.slice(0, -1).map((link) => {
          const isActive = currentPath === link.href || (link.href !== `/${lang}/` && currentPath.startsWith(link.href));
          return (
            <li>
              <a
                href={link.href}
                class={`block px-4 py-3 rounded-lg text-base font-medium transition-colors ${isActive ? 'bg-blue-50 text-electric' : 'text-slate-700 hover:bg-slate-50'}`}
                aria-current={isActive ? 'page' : undefined}
              >
                {t.nav[link.key as keyof typeof t.nav]}
              </a>
            </li>
          );
        })}
      </ul>
      <div class="border-t border-slate-border pt-4 mt-2 flex items-center justify-between gap-4">
        <LanguageSwitcher currentLang={lang} currentPath={currentPath} />
        <a
          href={`/${lang}/contact/`}
          class="inline-flex items-center gap-1.5 bg-electric text-white text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-blue-700 transition-colors"
        >
          {t.nav.contact}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-nav-btn');
  const menu = document.getElementById('mobile-menu');
  const iconHamburger = document.getElementById('icon-hamburger');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', !isOpen);
    iconHamburger?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });

  // Close menu when a nav link is clicked
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconHamburger?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
