---
import Page from '@/layouts/Page.astro';
import SubscriptionTable from '@/components/ui/SubscriptionTable.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import { getDictionary, getLocalizedPath } from '@/i18n/index';
import { SUPPORTED_LANGS } from '@/i18n/types';
import type { Lang } from '@/i18n/types';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = await getDictionary(lang);
const fc = t.fincaCare;
---

<Page
  lang={lang}
  t={t}
  title={t.meta.fincaCareTitle}
  description={t.meta.fincaCareDesc}
  canonicalPath="finca-care"
>
  <LocalBusinessSchema lang={lang} pageType="finca-care" pagePath="finca-care" slot="head" />

  <!-- Hero -->
  <section class="bg-slate-bg py-16 md:py-24 border-b border-slate-border">
    <div class="container-xl text-center max-w-3xl mx-auto">
      <span class="inline-block text-electric text-xs font-bold uppercase tracking-widest mb-3">
        {fc.badge}
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-navy mb-6">{fc.heading}</h1>
      <p class="text-slate-500 text-xl leading-relaxed">{fc.subheading}</p>
    </div>
  </section>

  <!-- Promotion Banner -->
  <section class="bg-electric/5 border-b border-electric/20 py-5">
    <div class="container-xl">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-6">
        <span class="shrink-0 bg-electric text-white text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-full">
          {fc.promotion.badge}
        </span>
        <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 flex-1">
          <p class="text-navy font-semibold text-sm">{fc.promotion.headline}</p>
          <p class="text-slate-500 text-sm hidden sm:block">—</p>
          <p class="text-slate-500 text-sm leading-snug">{fc.promotion.body}</p>
        </div>
        <p class="shrink-0 text-xs text-slate-400 italic">{fc.promotion.expiry}</p>
      </div>
    </div>
  </section>

  <!-- Billing Toggle + Plans -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container-xl max-w-6xl mx-auto">

      <!-- Toggle -->
      <div class="flex flex-col items-center gap-3 mb-12">
        <div class="inline-flex items-center bg-slate-bg border border-slate-border rounded-xl p-1.5 gap-1" role="group" aria-label="Billing period">
          <button
            id="btn-monthly"
            class="billing-btn px-6 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200 bg-white text-navy shadow-sm"
            aria-pressed="true"
          >
            {fc.billing.monthly}
          </button>
          <button
            id="btn-annual"
            class="billing-btn px-6 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200 text-slate-500 hover:text-navy flex items-center gap-2"
            aria-pressed="false"
          >
            {fc.billing.annual}
            <span class="bg-green-500 text-white text-xs font-bold px-2 py-0.5 rounded-full">
              {fc.billing.annualBadge}
            </span>
          </button>
        </div>
        <p id="annual-commitment-note" class="hidden text-xs text-slate-400 text-center">{fc.billing.annualNote}</p>
      </div>

      <SubscriptionTable t={t} lang={lang} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20 bg-slate-bg border-t border-slate-border" aria-labelledby="faq-heading">
    <div class="container-xl max-w-3xl mx-auto">
      <h2 id="faq-heading" class="text-3xl font-bold text-navy mb-10 text-center">
        {fc.faq.heading}
      </h2>
      <div class="flex flex-col gap-4">
        {fc.faq.items.map((item) => (
          <details class="group bg-white rounded-xl border border-slate-border overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none font-semibold text-navy hover:text-electric transition-colors">
              {item.q}
              <svg class="shrink-0 ml-4 w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 text-sm leading-relaxed border-t border-slate-border pt-4">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy py-16">
    <div class="container-xl text-center">
      <h2 class="text-3xl font-bold text-white mb-4">{t.ctaBanner.heading}</h2>
      <p class="text-slate-300 mb-8 max-w-lg mx-auto">{t.ctaBanner.subheading}</p>
      <a
        href={getLocalizedPath(lang, 'contact')}
        class="inline-flex items-center gap-2 bg-electric text-white font-semibold px-8 py-4 rounded-xl hover:bg-blue-400 transition-colors shadow-lg shadow-blue-900/40"
      >
        {t.ctaBanner.cta}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</Page>

<script>
  const btnMonthly = document.getElementById('btn-monthly');
  const btnAnnual = document.getElementById('btn-annual');
  const monthlyPrices = document.querySelectorAll('.plan-price-monthly');
  const annualPrices = document.querySelectorAll('.plan-price-annual');
  const annualNote = document.getElementById('annual-commitment-note');

  function setMonthly() {
    monthlyPrices.forEach(el => el.classList.remove('hidden'));
    annualPrices.forEach(el => el.classList.add('hidden'));
    annualNote?.classList.add('hidden');
    btnMonthly?.classList.add('bg-white', 'text-navy', 'shadow-sm');
    btnMonthly?.classList.remove('text-slate-500');
    btnMonthly?.setAttribute('aria-pressed', 'true');
    btnAnnual?.classList.remove('bg-white', 'text-navy', 'shadow-sm');
    btnAnnual?.classList.add('text-slate-500');
    btnAnnual?.setAttribute('aria-pressed', 'false');
  }

  function setAnnual() {
    monthlyPrices.forEach(el => el.classList.add('hidden'));
    annualPrices.forEach(el => el.classList.remove('hidden'));
    annualNote?.classList.remove('hidden');
    btnAnnual?.classList.add('bg-white', 'text-navy', 'shadow-sm');
    btnAnnual?.classList.remove('text-slate-500');
    btnAnnual?.setAttribute('aria-pressed', 'true');
    btnMonthly?.classList.remove('bg-white', 'text-navy', 'shadow-sm');
    btnMonthly?.classList.add('text-slate-500');
    btnMonthly?.setAttribute('aria-pressed', 'false');
  }

  btnMonthly?.addEventListener('click', setMonthly);
  btnAnnual?.addEventListener('click', setAnnual);
</script>
