---
import Page from '@/layouts/Page.astro';
import { getDictionary, getLocalizedPath } from '@/i18n/index';
import { SUPPORTED_LANGS } from '@/i18n/types';
import type { Lang } from '@/i18n/types';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = await getDictionary(lang);
const s = t.contact.success;
---

<Page
  lang={lang}
  t={t}
  title={`${s.heading} | NextGen Finca`}
  description={s.body}
  canonicalPath="contact/success"
>
  <section class="min-h-[70vh] flex items-center justify-center bg-slate-bg py-20 px-4">
    <div class="max-w-lg w-full text-center">

      <!-- Icon -->
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 mb-8">
        <svg class="text-green-600" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>

      <!-- Heading -->
      <h1 class="text-3xl md:text-4xl font-bold text-navy mb-4">
        {s.heading}
      </h1>

      <!-- Body -->
      <p class="text-slate-500 text-lg leading-relaxed mb-3">
        {s.body}
      </p>

      <!-- Spam note -->
      <p class="text-slate-400 text-sm mb-10">
        {s.checkEmail}
      </p>

      <!-- CTA -->
      <a
        href={getLocalizedPath(lang, '')}
        class="inline-flex items-center gap-2 bg-electric text-white font-semibold px-8 py-4 rounded-xl hover:bg-blue-700 transition-all shadow-lg shadow-blue-200 hover:shadow-xl hover:shadow-blue-300 hover:-translate-y-0.5"
      >
        {s.cta}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</Page>
