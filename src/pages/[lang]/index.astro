---
import Page from '@/layouts/Page.astro';
import HeroSection from '@/components/ui/HeroSection.astro';
import TrustBadge from '@/components/ui/TrustBadge.astro';
import ServiceCard from '@/components/ui/ServiceCard.astro';
import SubscriptionTable from '@/components/ui/SubscriptionTable.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import HowItWorks from '@/components/ui/HowItWorks.astro';
import LanguageSwitcher from '@/components/global/LanguageSwitcher.astro';
import { getDictionary, getLocalizedPath } from '@/i18n/index';
import { SUPPORTED_LANGS } from '@/i18n/types';
import { SERVICES } from '@/config/services';
import type { Lang } from '@/i18n/types';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = await getDictionary(lang);
---

<Page
  lang={lang}
  t={t}
  title={t.meta.homeTitle}
  description={t.meta.homeDesc}
  canonicalPath=""
>
  <LocalBusinessSchema lang={lang} pageType="home" slot="head" />
  <link rel="preload" as="image" href="/images/estate-dashboard.jpg" slot="head" />

  <!-- Promo banner -->
  <div class="bg-electric/5 border-b border-electric/20">
    <div class="container-xl py-3 flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4 text-center sm:text-left">
      <p class="text-navy text-sm leading-snug">{t.promoBanner.text}</p>
      <a
        href={getLocalizedPath(lang, 'finca-care')}
        class="shrink-0 text-electric text-sm font-semibold hover:underline whitespace-nowrap"
      >
        {t.promoBanner.linkLabel} →
      </a>
      <span class="text-slate-400 text-xs italic hidden sm:inline">{t.promoBanner.expiry}</span>
    </div>
  </div>

  <!-- Mobile-only language switcher strip (desktop nav already has this) -->
  <div class="md:hidden bg-white border-b border-slate-border">
    <div class="container-xl py-2 flex items-center justify-center gap-2">
      <svg class="w-3.5 h-3.5 text-slate-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
      <LanguageSwitcher currentLang={lang} currentPath={`/${lang}/`} />
    </div>
  </div>

  <!-- Hero -->
  <HeroSection t={t} lang={lang} />

  <HowItWorks t={t} lang={lang} />

  <!-- Why Us -->
  <TrustBadge t={t} />

  <!-- Services grid -->
  <section class="py-16 md:py-24 bg-white" aria-labelledby="services-heading">
    <div class="container-xl">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="inline-block text-electric text-xs font-bold uppercase tracking-widest mb-3">
          {t.servicesSection.badge}
        </span>
        <h2 id="services-heading" class="text-3xl md:text-4xl font-bold text-navy mb-4">
          {t.servicesSection.heading}
        </h2>
        <p class="text-slate-500 text-lg">
          {t.servicesSection.subheading}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {SERVICES.map((service) => (
          <ServiceCard
            icon={service.icon}
            title={t.services[service.id].title}
            description={t.services[service.id].shortDesc}
            href={getLocalizedPath(lang, `services/${service.slug}`)}
            ctaLabel={t.services[service.id].cta}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Finca Care teaser -->
  <section class="py-16 md:py-24 bg-slate-bg" aria-labelledby="finca-care-heading">
    <div class="container-xl">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="inline-block text-electric text-xs font-bold uppercase tracking-widest mb-3">
          {t.fincaCare.badge}
        </span>
        <h2 id="finca-care-heading" class="text-3xl md:text-4xl font-bold text-navy mb-4">
          {t.fincaCare.heading}
        </h2>
        <p class="text-slate-500 text-lg">
          {t.fincaCare.subheading}
        </p>
      </div>

      <SubscriptionTable t={t} lang={lang} />

      <div class="text-center mt-8">
        <a
          href={getLocalizedPath(lang, 'finca-care')}
          class="inline-flex items-center gap-2 text-electric font-semibold hover:underline text-sm"
        >
          {t.fincaCare.viewAllDetails}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ section -->
  <section class="py-16 md:py-20 bg-white" aria-labelledby="home-faq-heading">
    <div class="container-xl max-w-3xl mx-auto">
      <h2 id="home-faq-heading" class="text-3xl font-bold text-navy mb-10 text-center">
        {t.homeFaq.heading}
      </h2>
      <div class="flex flex-col gap-4">
        {t.homeFaq.items.map((item) => (
          <details class="group bg-slate-bg rounded-xl border border-slate-border overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none font-semibold text-navy hover:text-electric transition-colors">
              {item.q}
              <svg class="shrink-0 ml-4 w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 text-sm leading-relaxed border-t border-slate-border pt-4">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-navy py-16 md:py-20" aria-label="Call to action">
    <div class="container-xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        {t.ctaBanner.heading}
      </h2>
      <p class="text-slate-300 text-lg mb-8 max-w-xl mx-auto">
        {t.ctaBanner.subheading}
      </p>
      <a
        href={getLocalizedPath(lang, 'contact')}
        class="inline-flex items-center gap-2 bg-electric text-white font-semibold px-8 py-4 rounded-xl hover:bg-blue-400 transition-colors shadow-lg shadow-blue-900/40 text-lg"
      >
        {t.ctaBanner.cta}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</Page>
