---
import Page from '@/layouts/Page.astro';
import ServiceCard from '@/components/ui/ServiceCard.astro';
import ComplianceNotice from '@/components/ui/ComplianceNotice.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import { getDictionary, getLocalizedPath } from '@/i18n/index';
import { SUPPORTED_LANGS } from '@/i18n/types';
import { SERVICES } from '@/config/services';
import type { Lang } from '@/i18n/types';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = await getDictionary(lang);
---

<Page
  lang={lang}
  t={t}
  title={t.meta.servicesTitle}
  description={t.meta.servicesDesc}
  canonicalPath="services"
>
  <LocalBusinessSchema lang={lang} pageType="home" slot="head" />

  <!-- Page hero -->
  <section class="bg-slate-bg py-16 md:py-24 border-b border-slate-border">
    <div class="container-xl">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="inline-block text-electric text-xs font-bold uppercase tracking-widest mb-3">
          {t.servicesSection.badge}
        </span>
        <h1 class="text-4xl md:text-5xl font-bold text-navy mb-6">
          {t.servicesSection.heading}
        </h1>
        <p class="text-slate-500 text-xl leading-relaxed">
          {t.servicesSection.subheading}
        </p>
      </div>
      <figure class="max-w-4xl mx-auto">
        <img
          src="/images/smart-home-devices.jpg"
          alt="Smart home and IoT devices for estate management"
          class="w-full rounded-2xl shadow-lg object-cover aspect-[21/9]"
          width="1200"
          height="514"
        />
      </figure>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container-xl">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {SERVICES.map((service) => (
          <ServiceCard
            icon={service.icon}
            title={t.services[service.id].title}
            description={t.services[service.id].shortDesc}
            href={getLocalizedPath(lang, `services/${service.slug}`)}
            ctaLabel={t.services[service.id].cta}
          />
        ))}
      </div>

      <div class="mt-12">
        <ComplianceNotice t={t} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-slate-bg border-t border-slate-border py-16">
    <div class="container-xl text-center">
      <h2 class="text-2xl font-bold text-navy mb-4">{t.ctaBanner.heading}</h2>
      <a
        href={getLocalizedPath(lang, 'contact')}
        class="inline-flex items-center gap-2 bg-electric text-white font-semibold px-8 py-4 rounded-xl hover:bg-blue-700 transition-colors shadow-lg shadow-blue-200"
      >
        {t.hero.ctaPrimary}
      </a>
    </div>
  </section>
</Page>
