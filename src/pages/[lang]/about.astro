---
import Page from '@/layouts/Page.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import { getDictionary, getLocalizedPath } from '@/i18n/index';
import { SUPPORTED_LANGS } from '@/i18n/types';
import type { Lang } from '@/i18n/types';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = await getDictionary(lang);
const a = t.about;
---

<Page
  lang={lang}
  t={t}
  title={t.meta.aboutTitle}
  description={t.meta.aboutDesc}
  canonicalPath="about"
>
  <LocalBusinessSchema lang={lang} pageType="home" slot="head" />
  <!-- Hero -->
  <section class="bg-slate-bg py-12 md:py-16 border-b border-slate-border">
    <div class="container-xl max-w-3xl">
      <span class="inline-block text-electric text-xs font-bold uppercase tracking-widest mb-3">
        {a.badge}
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-navy mb-4">{a.heading}</h1>
      <p class="text-slate-500 text-lg leading-relaxed">{a.intro}</p>
    </div>
  </section>

  <!-- Story + Sidebar -->
  <section class="py-12 md:py-16 bg-white">
    <div class="container-xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-14">

        <!-- Story sections -->
        <div class="lg:col-span-2 flex flex-col gap-10">
          {a.sections.map((section) => (
            <div class="flex flex-col gap-3">
              <h2 class="text-xl font-bold text-navy flex items-center gap-3">
                <span class="w-1 h-5 bg-electric rounded-full shrink-0" aria-hidden="true"></span>
                {section.heading}
              </h2>
              <p class="text-slate-600 leading-relaxed pl-4">{section.body}</p>
            </div>
          ))}

          <!-- Closing CTA block -->
          <div class="bg-slate-bg rounded-2xl p-6 border border-slate-border">
            <h3 class="text-lg font-bold text-navy mb-2">{a.closingHeading}</h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-5">{a.closingBody}</p>
            <a
              href={getLocalizedPath(lang, 'contact')}
              class="inline-flex items-center gap-2 bg-electric text-white font-semibold px-5 py-2.5 rounded-xl hover:bg-blue-700 transition-colors text-sm"
            >
              {a.ctaLabel}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <div class="sticky top-24 flex flex-col gap-5">
            <div class="bg-navy rounded-2xl p-6 text-white">
              <p class="text-slate-400 text-xs uppercase tracking-widest mb-5">{a.glance.label}</p>
              <div class="flex flex-col gap-4">
                {a.glance.stats.map((stat, i) => (
                  <div class={i > 0 ? "border-t border-slate-700 pt-4 flex items-start gap-3" : "flex items-start gap-3"}>
                    <span class="text-electric text-xl font-bold shrink-0 w-10">{stat.value}</span>
                    <span class="text-slate-300 text-sm leading-snug">{stat.text}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="bg-slate-bg rounded-2xl p-5 border border-slate-border">
              <p class="text-navy text-xs font-bold uppercase tracking-widest mb-3">{a.glance.howWeWorkLabel}</p>
              <ul class="flex flex-col gap-2.5">
                {a.glance.howWeWorkItems.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-slate-600">
                    <span class="w-1.5 h-1.5 rounded-full bg-electric mt-1.5 shrink-0" aria-hidden="true"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- CTA banner -->
  <section class="bg-navy py-14">
    <div class="container-xl text-center">
      <h2 class="text-2xl font-bold text-white mb-3">{t.ctaBanner.heading}</h2>
      <p class="text-slate-300 mb-6 max-w-md mx-auto text-sm">{t.ctaBanner.subheading}</p>
      <a
        href={getLocalizedPath(lang, 'contact')}
        class="inline-flex items-center gap-2 bg-electric text-white font-semibold px-7 py-3.5 rounded-xl hover:bg-blue-400 transition-colors shadow-lg shadow-blue-900/40"
      >
        {t.ctaBanner.cta}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</Page>
