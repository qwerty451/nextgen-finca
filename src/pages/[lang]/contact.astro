---
import Page from '@/layouts/Page.astro';
import ContactForm from '@/components/ui/ContactForm.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import { getDictionary, getLocalizedPath } from '@/i18n/index';
import { SUPPORTED_LANGS } from '@/i18n/types';
import { REGIONS } from '@/config/site';
import type { Lang } from '@/i18n/types';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = await getDictionary(lang);

const url = Astro.url;
const showSuccess = url.searchParams.get('success') === '1';
---

<Page
  lang={lang}
  t={t}
  title={t.meta.contactTitle}
  description={t.meta.contactDesc}
  canonicalPath="contact"
>
  <LocalBusinessSchema lang={lang} pageType="contact" pageTitle={t.meta.contactTitle} pagePath="contact" slot="head" />

  <!-- Hero -->
  <section class="bg-slate-bg py-14 md:py-20 border-b border-slate-border">
    <div class="container-xl max-w-3xl">
      <span class="inline-block text-electric text-xs font-bold uppercase tracking-widest mb-3">
        Contact
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-navy mb-5">
        {t.contact.heading}
      </h1>
      <p class="text-slate-500 text-xl leading-relaxed">
        {t.contact.subheading}
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="py-14 md:py-20 bg-white">
    <div class="container-xl">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form (wider) -->
        <div class="lg:col-span-3">
          <ContactForm t={t} lang={lang} showSuccess={showSuccess} />
        </div>

        <!-- Info sidebar -->
        <aside class="lg:col-span-2 flex flex-col gap-8">
          <!-- Response promise -->
          <div class="bg-slate-bg rounded-2xl border border-slate-border p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-xl bg-electric/10 flex items-center justify-center shrink-0">
                <svg class="text-electric" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <p class="font-semibold text-navy text-sm">{t.contact.responsePromise}</p>
            </div>
          </div>

          <!-- WhatsApp -->
          <div class="bg-slate-bg rounded-2xl border border-slate-border p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center shrink-0">
                <svg class="text-green-600" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy text-sm">{t.contact.whatsappLabel}</p>
                <a
                  href="https://wa.me/34600000000"
                  class="text-green-600 text-sm hover:underline font-medium"
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  +34 600 000 000
                </a>
              </div>
            </div>
          </div>

          <!-- Regions -->
          <div class="bg-slate-bg rounded-2xl border border-slate-border p-6">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">
              {t.contact.regionsLabel}
            </p>
            <ul class="flex flex-col gap-1.5 list-none m-0 p-0">
              {REGIONS.map((region) => (
                <li class="flex items-center gap-2 text-sm text-navy font-medium">
                  <span class="w-1.5 h-1.5 rounded-full bg-electric shrink-0" aria-hidden="true"></span>
                  {region}
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Page>
